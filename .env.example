# Copy this file to .env and fill in your API keys

# USDA AMS Market News API (free — register at mymarketnews.ams.usda.gov)
USDA_AMS_API_KEY=

# USDA NASS Quick Stats API (free — register at quickstats.nass.usda.gov)
USDA_NASS_API_KEY=

# NOAA Climate Data Online API (free — register at www.ncdc.noaa.gov/cdo-web)
NOAA_API_KEY=

# EIA Open Data API (free — register at www.eia.gov/opendata)
EIA_API_KEY=

# App security
SECRET_KEY=change-this-to-a-random-secret-in-production

# Email alerts (optional)
SENDGRID_API_KEY=
ALERT_FROM_EMAIL=alerts@hayprice.io

# Debug mode
DEBUG=true
